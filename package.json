{
  "name": "eagle-bank",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Eagle Bank REST API",
  "packageManager": "npm@11.9.0",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "api:dev": "tsx watch src/server.ts",
    "auth:dev": "tsx watch src/services/auth-server.ts",
    "ledger:dev": "tsx watch src/services/ledger-server.ts",
    "ledger-event-publisher:dev": "tsx watch src/services/ledger-event-publisher.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "npm run test:unit && npm run test:integration",
    "verify": "npm run lint && npm run format && npm run test:unit && npm run test:integration && npm run infra:test",
    "test:unit": "vitest run --config vitest.unit.config.ts --coverage",
    "test:integration": "sh scripts/run-integration-tests.sh",
    "test:integration:run": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "test:coverage": "npm run test:unit",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p infra/tsconfig.json",
    "lint": "eslint . && tsc -p tsconfig.json --noEmit && tsc -p infra/tsconfig.json",
    "format": "prettier --check .",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "smoke": "bash scripts/smoke-test.sh",
    "infra:test": "vitest run --config vitest.infra.config.ts",
    "infra:synth": "cdk synth --no-lookups",
    "infra:diff": "cdk diff",
    "infra:deploy": "cdk deploy",
    "infra:destroy": "cdk destroy"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^14.2.1",
    "@aws-sdk/client-dynamodb": "^3.828.0",
    "@aws-sdk/client-sqs": "^3.828.0",
    "@aws-sdk/lib-dynamodb": "^3.828.0",
    "@fastify/jwt": "^10.1.0",
    "@prisma/client": "^6.19.0",
    "ajv-formats": "^3.0.1",
    "argon2": "^0.44.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "openapi-backend": "^5.11.1",
    "pino": "^10.1.0",
    "prisma": "^6.19.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.150",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.1.8",
    "aws-cdk": "^2.1126.0",
    "aws-cdk-lib": "^2.201.0",
    "constructs": "^10.4.2",
    "eslint": "^10.5.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.6",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  }
}
