generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  personal
}

enum TransactionType {
  deposit
  withdrawal
}

enum AccountStatus {
  PENDING_LEDGER_CREATION
  ACTIVE
  LEDGER_CREATION_FAILED
  PENDING_LEDGER_CLOSURE
  LEDGER_CLOSURE_FAILED
  CLOSED
}

enum LedgerAccountStatus {
  ACTIVE
  CLOSED
}

enum LedgerEntryDirection {
  CREDIT
  DEBIT
}

enum LedgerRecordStatus {
  POSTED
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
  DEAD
}

model User {
  id           String        @id
  name         String
  addressLine1 String
  addressLine2 String?
  addressLine3 String?
  town         String
  county       String
  postcode     String
  phoneNumber  String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  accounts     BankAccount[]
}

model BankAccount {
  id                          String         @id @default(uuid()) @db.Uuid
  accountNumber               String         @unique
  sortCode                    String         @default("10-10-10")
  name                        String
  accountType                 AccountType
  balance                     Decimal        @default(0) @db.Decimal(12, 2)
  currency                    String         @default("GBP")
  userId                      String
  status                      AccountStatus  @default(PENDING_LEDGER_CREATION)
  deletedAt                   DateTime?
  reconciliationCorrelationId String?
  user                        User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  transactions                Transaction[]
  ledgerAccount               LedgerAccount?
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  @@index([userId, status, createdAt])
  @@index([status, updatedAt])
}

model Transaction {
  id        String          @id
  amount    Decimal         @db.Decimal(12, 2)
  currency  String
  type      TransactionType
  reference String?
  userId    String
  accountId String          @db.Uuid
  account   BankAccount     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  createdAt DateTime        @default(now())

  @@index([accountId, createdAt])
}

model LedgerAccount {
  id               String              @id @default(uuid()) @db.Uuid
  accountId        String              @unique @db.Uuid
  accountNumber    String              @unique
  userId           String
  currency         String              @default("GBP")
  availableBalance Decimal             @default(0) @db.Decimal(12, 2)
  status           LedgerAccountStatus @default(ACTIVE)
  version          Int                 @default(0)
  account          BankAccount         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  transactions     LedgerTransaction[]
  entries          LedgerEntry[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model LedgerTransaction {
  id              String             @id @default(uuid()) @db.Uuid
  transactionId   String             @unique
  ledgerAccountId String             @db.Uuid
  accountId       String             @db.Uuid
  accountNumber   String
  userId          String
  type            TransactionType
  amount          Decimal            @db.Decimal(12, 2)
  currency        String
  reference       String?
  status          LedgerRecordStatus @default(POSTED)
  idempotencyKey  String?
  ledgerAccount   LedgerAccount      @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)
  entries         LedgerEntry[]
  createdAt       DateTime           @default(now())

  @@index([ledgerAccountId, createdAt, id])
}

model LedgerEntry {
  id                  String               @id @default(uuid()) @db.Uuid
  ledgerTransactionId String               @db.Uuid
  ledgerAccountId     String               @db.Uuid
  accountId           String               @db.Uuid
  direction           LedgerEntryDirection
  amount              Decimal              @db.Decimal(12, 2)
  currency            String
  balanceAfter        Decimal              @db.Decimal(12, 2)
  ledgerTransaction   LedgerTransaction    @relation(fields: [ledgerTransactionId], references: [id], onDelete: Restrict)
  ledgerAccount       LedgerAccount        @relation(fields: [ledgerAccountId], references: [id], onDelete: Restrict)
  createdAt           DateTime             @default(now())

  @@index([ledgerTransactionId])
  @@index([ledgerAccountId, createdAt, id])
}

model LedgerIdempotencyKey {
  id              String            @id @default(uuid()) @db.Uuid
  idempotencyKey  String
  userId          String
  accountNumber   String
  requestHash     String
  status          IdempotencyStatus @default(PROCESSING)
  responsePayload Json?
  createdAt       DateTime          @default(now())
  expiresAt       DateTime

  @@unique([userId, accountNumber, idempotencyKey])
  @@index([expiresAt])
}

model LedgerOutboxEvent {
  id                       String       @id @default(uuid()) @db.Uuid
  eventId                  String       @unique
  eventType                String
  aggregateId              String
  payload                  Json
  status                   OutboxStatus @default(PENDING)
  attempts                 Int          @default(0)
  nextAttemptAt            DateTime     @default(now())
  processingLeaseExpiresAt DateTime?
  lastError                String?
  publishedAt              DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@index([status, nextAttemptAt, createdAt])
  @@index([status, processingLeaseExpiresAt])
}
