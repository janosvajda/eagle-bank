NODE_ENV=local
PORT=3000
DATABASE_URL=postgresql://eagle:eagle@localhost:5432/eagle_bank?schema=public
# Signs public user access tokens.
JWT_SECRET=replace-with-at-least-32-characters
JWT_EXPIRES_IN=1h
AUTH_SESSION_TTL_SECONDS=3600
AWS_REGION=eu-west-2
DYNAMODB_AUTH_SESSIONS_TABLE=eagle-bank-auth-sessions
# Audience-specific API-to-service keys; all three JWT keys must differ.
AUTH_SERVICE_JWT_SECRET=replace-with-an-auth-service-32-character-secret
LEDGER_SERVICE_JWT_SECRET=replace-with-a-ledger-service-32-character-secret
